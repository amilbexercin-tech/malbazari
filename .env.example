# MalBazari.biz — nümunə konfiqurasiya
# Bu faylı ".env" adı ilə kopyalayın və dəyərləri doldurun:
#   cp .env.example .env
# .env faylı git-ə düşmür (məxfidir).

# ── Təhlükəsizlik ──
# Production-da öz təsadüfi açarınızı qoyun:
#   python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# HTTPS arxasında (production) 1 edin; lokal HTTP-də boş saxlayın
SESSION_COOKIE_SECURE=

# Lokal inkişaf üçün debug (production-da BOŞ saxla!)
FLASK_DEBUG=

# ── İlk admin (yalnız boş bazanı doldurmaq üçün) ──
ADMIN_PHONE=
ADMIN_PASSWORD=

# ── SMS (telefon təsdiqi / parol bərpası) ──
# Telefon təsdiqi məcburi olsun? Hələlik boş (söndürülü). Real SMS qoşanda 1 et.
REQUIRE_PHONE_VERIFICATION=

# dev   = real SMS yox, kod ekranda göstərilir (test)
# twilio = real SMS göndərilir
SMS_PROVIDER=dev

# Twilio üçün (SMS_PROVIDER=twilio olduqda):
SMS_ACCOUNT_SID=
SMS_API_KEY=
SMS_SENDER=
