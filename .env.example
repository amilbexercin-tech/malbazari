# MalBazari.biz — nümunə konfiqurasiya
# Bu faylı ".env" adı ilə kopyalayın və dəyərləri doldurun:
#   cp .env.example .env
# .env faylı git-ə düşmür (məxfidir).

# ── Kalıcı disk (ÇOX VACİB — production) ──
# Railway-də Volume yarat və mount path-ı bura yaz (məs. /data).
# DATA_DIR Volume mount path ilə EYNİ olmalıdır, yoxsa hər deploy-da
# baza və şəkillər SİLİNİR (elanlar yox olur, admin 2FA sıfırlanır).
DATA_DIR=

# ── Təhlükəsizlik ──
# Production-da öz təsadüfi açarınızı qoyun:
#   python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# HTTPS arxasında (production) 1 edin; lokal HTTP-də boş saxlayın
SESSION_COOKIE_SECURE=

# Lokal inkişaf üçün debug (production-da BOŞ saxla!)
FLASK_DEBUG=

# ── İlk admin (yalnız boş bazanı doldurmaq üçün) ──
ADMIN_PHONE=
ADMIN_PASSWORD=

# ── SMS (telefon təsdiqi / parol bərpası) ──
# Telefon təsdiqi məcburi olsun? Hələlik boş (söndürülü). Real SMS qoşanda 1 et.
REQUIRE_PHONE_VERIFICATION=

# dev   = real SMS yox, kod ekranda göstərilir (test)
# twilio = real SMS göndərilir
SMS_PROVIDER=dev

# Avtomatik gündəlik yedək (defolt aktiv). Söndürmək üçün 0.
AUTO_BACKUP=1

# ── Kənar (offsite) yedək — Telegram ──
# Avtomatik gündəlik yedək zip-i Telegram-a göndərilsin (ehtiyat nüsxə).
# Boş saxlasan söndürülü. Bot: @BotFather; chat id: @userinfobot və ya öz nömrən.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Monitorinq ──
# Sentry — kod xətası olanda səbəbi ilə xəbər. Boş saxlasan söndürülü.
# sentry.io-da pulsuz layihə yarat və DSN-i bura yaz.
SENTRY_DSN=

# Twilio üçün (SMS_PROVIDER=twilio olduqda):
SMS_ACCOUNT_SID=
SMS_API_KEY=
SMS_SENDER=
